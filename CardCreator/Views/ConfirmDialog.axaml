<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="CardCreator.Views.ConfirmDialog"
        Title="Confirm"
        Width="300"
        Height="150"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="#2a2a2a"
        Foreground="White">

    <Border Padding="20">
        <Grid RowDefinitions="*,Auto">
            <TextBlock x:Name="MessageText" 
                       Grid.Row="0"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Foreground="White"
                       FontSize="14"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="ConfirmButton" Content="Confirm" Width="80" 
                        Background="#444" Foreground="White" Padding="8,6"/>
                <Button x:Name="CancelButton" Content="Cancel" Width="80"
                        Background="#555" Foreground="White" Padding="8,6"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
